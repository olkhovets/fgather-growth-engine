// Prisma schema for Gather Growth Engine
// SQLite for local dev (zero cost); Postgres for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  emailVerificationToken String? @unique
  password      String?   // hashed with bcrypt
  image         String?
  accounts      Account[]
  sessions      Session[]
  workspace     Workspace?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Workspace {
  id              String   @id @default(cuid())
  userId          String   @unique
  domain          String?  // e.g. "acme.com"
  anthropicKey    String?  // encrypted
  instantlyKey    String?  // encrypted
  lumaApiKey      String?  // encrypted — for AI video (Luma Dream Machine)
  runwayApiKey    String?  // encrypted — for AI video (Runway Gen-3)
  productSummary  String?  // populated after crawl
  icp             String?  // Ideal Customer Profile (free text)
  proofPointsJson String?  // JSON: [{ title?: string; text: string }]
  socialProofJson String? // JSON: { similarCompanies?: string; referralPhrase?: string }
  playbookJson    String?  // JSON: { steps: [{ subject, body, delayDays }] }
  playbookApproved Boolean @default(false)
  anthropicModel   String?  // e.g. claude-3-5-haiku, claude-3-5-sonnet (defaults to first in list if unset)
  senderName       String?  // e.g. "John Smith, Gather" — used to sign off emails (never use recipient's name)
  webhookSecret    String?  // shared secret to verify inbound Instantly webhook calls
  notifyEmail      String?  // where to send positive-reply alerts (defaults to user email)
  apolloApiKey     String?  // encrypted — for automated lead ingestion from Apollo
  apolloSearchJson String?  // JSON: saved Apollo search params for the auto-ingest cron
  learningsJson    String?  // JSON: string[] of proven message patterns (promoted experiment winners) injected into all future generation
  autopilot        Boolean  @default(false) // when true, the daily orchestrator generates AND sends without manual approval
  customInstructions String? // free-text addendum injected into every generation prompt (e.g. "offer a $100 Uber Eats card for booked demos")
  autopilotDailyLimit Int    @default(200) // max leads autopilot generates+sends per day
  inboxDailyLimit  Int?     // per-warmed-inbox daily send cap applied in Instantly (default 30; raise only for well-aged inboxes)
  incentiveConfigJson String? // Incentives Lab: { subjectTemplate, bodyTemplate, amounts: number[] }
  incentivesAutopilot Boolean @default(false) // when true, the orchestrator auto-pulls fresh leads (when low) and appends them into the rolling Incentives Lab campaign
  incentivesPerRun     Int      @default(50)   // leads appended into the rolling campaign per autopilot run
  incentivesIntervalMin Int     @default(30)   // minimum minutes between incentives-autopilot runs (paces sending)
  incentivesDailyCap   Int      @default(500)  // max leads/day the incentives autopilot will append
  incentivesLastRunAt  DateTime?               // when the incentives autopilot last appended (for interval pacing)
  schedulingLink   String?  // real Calendly/booking link. Blank = NEVER include links. Set = used only in follow-up steps, never step 1.
  notifyOnActivity Boolean  @default(false) // email the operator on every activity-log event
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadBatches    LeadBatch[]
  sentCampaigns SentCampaign[]
  campaigns     Campaign[]
  performanceObservations PerformanceObservation[]
  promptExperiments PromptExperiment[]
  activityLogs   ActivityLog[]
}

model Campaign {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String   // e.g. "Q1 Outbound"
  status          String   // "draft" | "sequences_ready" | "launched"
  playbookJson    String?  // { steps: [{ subject, body, delayDays }] }
  icp             String?
  proofPointsJson String?
  leadBatchId     String?  // set when leads added for this campaign
  ctaUrl          String?  // CTA URL shown on personalized landing pages
  builderPrefsJson String? // builder UI prefs: { useFastModel, useWebScraping, useLandingPage, useVideo, selectedAccountEmails }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadBatch   LeadBatch?    @relation(fields: [leadBatchId], references: [id], onDelete: SetNull)
  sentCampaigns SentCampaign[]
}

// Append-only audit log of everything the engine does — generation, sends,
// Apollo ingests, experiment promotions, replies, autopilot runs. Surfaced on
// the activity dashboard so the operator can see what happened and the stats.
model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // "generate" | "send" | "ingest" | "experiment" | "reply" | "autopilot" | "info"
  message     String   // human-readable summary
  metaJson    String?  // JSON: structured stats for the row
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

// A single self-improving message experiment. The engine generates these as
// hypotheses, tags generated leads with the variants used, then promotes
// winners (folded into Workspace.learningsJson) and kills losers based on
// per-lead positive-reply attribution.
model PromptExperiment {
  id            String   @id @default(cuid())
  workspaceId   String
  dimension     String   // "subject" | "hook" | "cta" | "incentive"
  label         String   // short human-readable name
  instruction   String   // the directive injected into the generation prompt
  hypothesis    String?  // why we're testing this (1-2 sentences)
  status        String   @default("testing") // "testing" | "winner" | "killed"
  generation    Int      @default(1) // which round of generation produced this
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dimension, status])
}

model PerformanceObservation {
  id             String   @id @default(cuid())
  workspaceId    String
  dimensionType  String   // "persona" | "vertical"
  dimensionValue String   // e.g. "VP Sales", "SaaS"
  metric         String   // "open_rate_pct" | "click_rate_pct" | "reply_count" | "positive_reply_count" | "objection_count" | "ooo_count" | "not_interested_count"
  value          Float    // rate (0-100) or count
  sourceType     String   // "campaign" | "reply"
  sourceId       String   // sentCampaignId or campaignReplyId
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SentCampaign {
  id                   String   @id @default(cuid())
  workspaceId          String
  campaignId           String?  // when launched from a Campaign flow
  leadBatchId          String?
  instantlyCampaignId  String   // Instantly API campaign id
  name                 String   // campaign name in Instantly
  abGroupId            String?  // when set, this campaign is part of an A/B test group
  variant              String?  // "A" | "B" when part of A/B test
  createdAt            DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  leadBatch LeadBatch?  @relation(fields: [leadBatchId], references: [id], onDelete: SetNull)
  replies   CampaignReply[]
}

model CampaignReply {
  id             String   @id @default(cuid())
  sentCampaignId String
  fromEmail      String
  subject        String?
  bodySnippet    String?  // first ~500 chars for display
  classification String?  // positive | objection | ooo | not_interested | other
  createdAt      DateTime @default(now())

  sentCampaign SentCampaign @relation(fields: [sentCampaignId], references: [id], onDelete: Cascade)
}

model LeadBatch {
  id          String   @id @default(cuid())
  workspaceId String
  name        String?  // optional label
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]
  sentCampaigns SentCampaign[]
  leads       Lead[]
}

model Lead {
  id                 String    @id @default(cuid())
  leadBatchId        String
  email              String
  name               String?
  jobTitle           String?
  company            String?
  website            String?   // company URL for web scraping
  industry           String?
  landingPageToken   String?   // token for personalized landing page
  landingPageContentJson String? // JSON: LandingPageContent generated at sequence-gen time
  videoUrl           String?   // URL of generated personalized video
  videoTaskId        String?   // Luma/Runway task ID for polling
  videoTaskProvider  String?   // "luma" | "runway"
  emailVerified      Boolean?  // true/false after verify step; null = not checked
  persona            String?   // from classify (e.g. "VP Sales")
  vertical           String?   // from classify (e.g. "SaaS")
  step1Subject       String?   // personalized first email subject (legacy; also in stepsJson)
  step1Body          String?   // personalized first email body
  step2Subject       String?
  step2Body          String?
  step3Subject       String?
  step3Body          String?
  stepsJson          String?   // JSON: [{ subject, body }] for dynamic N steps (1..10)
  linkedinMessage    String?   // personalized LinkedIn connection request (when playbook includes LinkedIn step)
  abVariant          String?   // "A" | "B" when sent as part of A/B test
  emailStyle         String?   // "pain-led" | "social-proof" | "direct-ask" | "insight-hook"
  sentAt             DateTime? // when lead was uploaded to Instantly for sending
  replyStatus        String?   // positive | objection | ooo | not_interested | other — set by reply webhook
  repliedAt          DateTime? // when a reply was received
  requeueAt          DateTime? // for OOO replies: re-contact after this date
  suppressed         Boolean   @default(false) // true = never contact again (negative reply / bounce)
  bouncedAt          DateTime? // set by the bounce webhook; drives suppression + the bounce-rate guardrail
  wildcardApproach   String?   // if set, this lead got a radical "wildcard" email style — label for per-approach reply tracking
  incentiveAmount    Int?      // Incentives Lab: dollar amount offered to this lead (for per-amount A/B tracking)
  incentiveSubjectStyle String? // Incentives Lab: which subject-style variant this lead got (for style A/B)
  emailProvider      String?   // inbox provider (Google / Microsoft / Yahoo / Other) — classified by MX at ingest, for provider analytics
  experimentIdsJson  String?   // JSON: string[] of PromptExperiment ids used to write this lead (for attribution)
  createdAt          DateTime  @default(now())

  leadBatch LeadBatch @relation(fields: [leadBatchId], references: [id], onDelete: Cascade)
}

model ErrorReport {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  context     String   // e.g. "Sequence generation failed"
  error       String
  extraJson   String?  // JSON blob of extra context
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  notifiedAt  DateTime? // when fix notification was sent to user
  createdAt   DateTime @default(now())
}
