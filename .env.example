# Gather Growth Engine — copy to .env and fill in

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Database (SQLite for dev; migrate to Postgres for production)
DATABASE_URL="file:./dev.db"

# Encryption key for API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-encryption-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (optional - show "Continue with Google" on login/signup)
# Create OAuth client at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true

# Email sending (optional - for production)
# Get free API key from https://resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Admin analytics (comma-separated emails allowed to access /admin)
# ADMIN_EMAILS=you@example.com,other@example.com

# Note: Users provide their own API keys (Anthropic, Instantly, etc.)
# These are stored encrypted in the database per user.
# No project-level API keys needed — users bring their own.
# In dev mode, verification emails are logged to console instead of sent.

# --- LinkedIn forward pipe (engine → ad-drafter Google Sheet). Optional. ---
# Deploy linkedin-ad-drafter/sheet-append.gs as a web app and paste its /exec URL.
# When LINKEDIN_SHEET_APPEND_URL is unset, /api/linkedin/push-ads runs as a SAFE
# DRY RUN (generates ad rows, writes nothing). DESTINATION_URL is the landing/
# booking link placed on the generated ads.
# LINKEDIN_SHEET_APPEND_URL=https://script.google.com/macros/s/.../exec
# LINKEDIN_SHEET_APPEND_TOKEN=optional-shared-secret-matching-the-gs
# LINKEDIN_SHEET_TAB=Engine
# LINKEDIN_AD_DESTINATION_URL=https://calendly.com/your-demo-link
